# Copy to .env in this folder (backend/.env):
#   cp env.example .env
# Local MongoDB (install + run: mongod, or Docker: docker run -d -p 27017:27017 mongo:7)
MONGO_URL=mongodb://127.0.0.1:27017
DB_NAME=tennis_buddies

# Optional; min length handled in code if shorter
JWT_SECRET=tennis-buddies-dev-secret-change-me-32chars

# Optional integrations
# EMERGENT_LLM_KEY=
# RESEND_API_KEY=
